{
  "name": "tontine-backend",
  "version": "1.0.0",
  "description": "API backend de l'application Tontine",
  "main": "src/app.js",
  "scripts": {
    "start": "prisma generate && prisma db execute --file ./prisma/migrate_safe.sql --schema ./prisma/schema.prisma && node src/app.js",
    "dev": "nodemon src/app.js",
    "build": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:generate": "prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "africastalking": "^0.8.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "google-auth-library": "^10.6.2",
    "helmet": "^7.1.0",
    "joi": "^17.12.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.9",
    "otplib": "^12.0.1",
    "pdfkit": "^0.14.0",
    "prisma": "5.22.0",
    "qrcode": "^1.5.3",
    "socket.io": "^4.6.2",
    "uuid": "^9.0.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
