// Tontine App - Schéma Prisma complet
// Base de données : PostgreSQL

generator client {
  provider      = "prisma-client-js"
  output        = "../src/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// UTILISATEURS & AUTHENTIFICATION
// ─────────────────────────────────────────

model User {
  id               String   @id @default(uuid())
  nom              String
  prenom           String
  email            String?  @unique
  telephone        String?  @unique
  passwordHash     String?
  googleId         String?  @unique
  avatarUrl        String?
  scoreFilabilite  Float    @default(100.0)
  twoFaSecret      String?
  twoFaActive      Boolean  @default(false)
  isVerified       Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  tontinesMembres   TontineMembre[]
  paiementsEffectues Paiement[]      @relation("payeur")
  emprunts          Emprunt[]
  remboursements    Remboursement[]
  disputesSignales  Litige[]        @relation("rapporteur")
  votesLitiges      VoteLitige[]
  messages          Message[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  swapsRequetes     EchangePosition[] @relation("demandeur")
  swapsCibles       EchangePosition[] @relation("cible")
  signaturesReg     SignatureReglement[]
  tontinesCreees    Tontine[]

  @@map("users")
}

// ─────────────────────────────────────────
// TONTINES
// ─────────────────────────────────────────

enum FrequenceTontine {
  HEBDOMADAIRE
  BIMENSUELLE
  MENSUELLE
  TRIMESTRIELLE
}

enum ModeTirage {
  ALEATOIRE
  MANUEL
  ENCHERES
}

enum TypePenalite {
  FIXE
  POURCENTAGE
}

enum StatutTontine {
  BROUILLON
  OUVERTE
  EN_COURS
  SUSPENDUE
  TERMINEE
}

model Tontine {
  id               String          @id @default(uuid())
  nom              String
  description      String?
  montantCotisation Decimal        @db.Decimal(15, 2)
  frequence        FrequenceTontine
  nombreMembres    Int
  modeTirage       ModeTirage      @default(ALEATOIRE)
  typePenalite     TypePenalite    @default(POURCENTAGE)
  valeurPenalite   Decimal         @db.Decimal(10, 2) @default(5.0)
  delaiPenaliteJours Int           @default(3)
  avecCredit       Boolean         @default(false)
  tauxInteretCredit Decimal?       @db.Decimal(5, 2)
  statut           StatutTontine   @default(BROUILLON)
  codeInvitation   String          @unique @default(cuid())
  createur         User            @relation(fields: [createurId], references: [id])
  createurId       String
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  // Relations
  membres          TontineMembre[]
  cycles           Cycle[]
  reglements       Reglement[]
  emprunts         Emprunt[]
  litiges          Litige[]
  messages         Message[]
  auditLogs        AuditLog[]
  echanges         EchangePosition[]

  @@map("tontines")
}

// ─────────────────────────────────────────
// MEMBRES DE TONTINE
// ─────────────────────────────────────────

enum RoleMembre {
  ADMINISTRATEUR
  TRESORIER
  MEMBRE
}

enum StatutMembre {
  EN_ATTENTE
  ACTIF
  SUSPENDU
  EXCLU
  SORTI
}

model TontineMembre {
  id          String       @id @default(uuid())
  tontine     Tontine      @relation(fields: [tontineId], references: [id])
  tontineId   String
  membre      User         @relation(fields: [membreId], references: [id])
  membreId    String
  role        RoleMembre   @default(MEMBRE)
  position    Int?
  statut      StatutMembre @default(EN_ATTENTE)
  montantEnchere Decimal? @db.Decimal(15, 2)
  rejointLe   DateTime     @default(now())
  sortLe      DateTime?

  @@unique([tontineId, membreId])
  @@unique([tontineId, position])
  @@map("tontine_membres")
}

// ─────────────────────────────────────────
// CYCLES & SESSIONS
// ─────────────────────────────────────────

enum StatutCycle {
  EN_COURS
  TERMINE
  SUSPENDU
}

model Cycle {
  id           String      @id @default(uuid())
  tontine      Tontine     @relation(fields: [tontineId], references: [id])
  tontineId    String
  numeroCycle  Int
  dateDebut    DateTime
  dateFin      DateTime?
  statut       StatutCycle @default(EN_COURS)
  createdAt    DateTime    @default(now())

  sessions     Session[]

  @@unique([tontineId, numeroCycle])
  @@map("cycles")
}

enum StatutSession {
  PLANIFIEE
  EN_COURS
  COTISATION_FERMEE
  DISTRIBUEE
  ANNULEE
}

model Session {
  id              String        @id @default(uuid())
  cycle           Cycle         @relation(fields: [cycleId], references: [id])
  cycleId         String
  numeroSession   Int
  datePlanifiee   DateTime
  dateEffective   DateTime?
  beneficiaireId  String?
  montantDistribue Decimal?     @db.Decimal(15, 2)
  statut          StatutSession @default(PLANIFIEE)
  createdAt       DateTime      @default(now())

  paiements       Paiement[]

  @@unique([cycleId, numeroSession])
  @@map("sessions")
}

// ─────────────────────────────────────────
// PAIEMENTS & REÇUS
// ─────────────────────────────────────────

enum StatutPaiement {
  EN_ATTENTE
  VALIDE
  REJETE
  REMBOURSE
}

enum MethodePaiement {
  ESPECES
  VIREMENT
  ORANGE_MONEY
  MTN_MONEY
  WAVE
  AUTRE
}

model Paiement {
  id              String          @id @default(uuid())
  session         Session         @relation(fields: [sessionId], references: [id])
  sessionId       String
  payeur          User            @relation("payeur", fields: [payeurId], references: [id])
  payeurId        String
  montant         Decimal         @db.Decimal(15, 2)
  montantPenalite Decimal         @db.Decimal(15, 2) @default(0)
  methodePaiement MethodePaiement @default(ESPECES)
  statut          StatutPaiement  @default(EN_ATTENTE)
  numerRecu       String          @unique @default(cuid())
  reference       String?
  note            String?
  payeLe          DateTime?
  enregistreLe    DateTime        @default(now())
  valideLe        DateTime?
  valideParId     String?

  @@map("paiements")
}

// ─────────────────────────────────────────
// RÈGLEMENT INTÉRIEUR
// ─────────────────────────────────────────

model Reglement {
  id          String   @id @default(uuid())
  tontine     Tontine  @relation(fields: [tontineId], references: [id])
  tontineId   String
  contenu     String
  version     Int      @default(1)
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())

  signatures  SignatureReglement[]

  @@map("reglements")
}

model SignatureReglement {
  id           String    @id @default(uuid())
  reglement    Reglement @relation(fields: [reglementId], references: [id])
  reglementId  String
  membre       User      @relation(fields: [membreId], references: [id])
  membreId     String
  signeLe      DateTime  @default(now())
  adresseIp    String?
  userAgent    String?

  @@unique([reglementId, membreId])
  @@map("signatures_reglement")
}

// ─────────────────────────────────────────
// ÉCHANGES DE POSITION
// ─────────────────────────────────────────

enum StatutEchange {
  EN_ATTENTE
  ACCEPTE
  REFUSE
  ANNULE
}

model EchangePosition {
  id            String        @id @default(uuid())
  tontine       Tontine       @relation(fields: [tontineId], references: [id])
  tontineId     String
  demandeur     User          @relation("demandeur", fields: [demandeurId], references: [id])
  demandeurId   String
  cible         User          @relation("cible", fields: [cibleId], references: [id])
  cibleId       String
  positionDemandeur Int
  positionCible    Int
  statut        StatutEchange @default(EN_ATTENTE)
  message       String?
  createdAt     DateTime      @default(now())
  resolvedAt    DateTime?

  @@map("echanges_position")
}

// ─────────────────────────────────────────
// EMPRUNTS & REMBOURSEMENTS
// ─────────────────────────────────────────

enum StatutEmprunt {
  EN_ATTENTE
  APPROUVE
  REFUSE
  EN_COURS
  REMBOURSE
  EN_RETARD
}

model Emprunt {
  id              String        @id @default(uuid())
  tontine         Tontine       @relation(fields: [tontineId], references: [id])
  tontineId       String
  emprunteur      User          @relation(fields: [emprunteurId], references: [id])
  emprunteurId    String
  montant         Decimal       @db.Decimal(15, 2)
  tauxInteret     Decimal       @db.Decimal(5, 2)
  dureeRemboursement Int
  montantTotal    Decimal       @db.Decimal(15, 2)
  statut          StatutEmprunt @default(EN_ATTENTE)
  motif           String?
  dateApprobation DateTime?
  dateFin         DateTime?
  createdAt       DateTime      @default(now())

  remboursements  Remboursement[]

  @@map("emprunts")
}

model Remboursement {
  id          String   @id @default(uuid())
  emprunt     Emprunt  @relation(fields: [empruntId], references: [id])
  empruntId   String
  emprunteur  User     @relation(fields: [emprunteurId], references: [id])
  emprunteurId String
  montant     Decimal  @db.Decimal(15, 2)
  payeLe      DateTime @default(now())
  note        String?

  @@map("remboursements")
}

// ─────────────────────────────────────────
// LITIGES & VOTES
// ─────────────────────────────────────────

enum StatutLitige {
  OUVERT
  EN_VOTE
  RESOLU
  FERME
}

enum TypeLitige {
  PAIEMENT
  COMPORTEMENT
  REGLEMENT
  DISTRIBUTION
  AUTRE
}

model Litige {
  id           String       @id @default(uuid())
  tontine      Tontine      @relation(fields: [tontineId], references: [id])
  tontineId    String
  rapporteur   User         @relation("rapporteur", fields: [rapporteurId], references: [id])
  rapporteurId String
  type         TypeLitige   @default(AUTRE)
  description  String
  statut       StatutLitige @default(OUVERT)
  resolution   String?
  createdAt    DateTime     @default(now())
  resolvedAt   DateTime?

  votes        VoteLitige[]

  @@map("litiges")
}

model VoteLitige {
  id        String   @id @default(uuid())
  litige    Litige   @relation(fields: [litigeId], references: [id])
  litigeId  String
  votant    User     @relation(fields: [votantId], references: [id])
  votantId  String
  vote      Boolean
  commentaire String?
  voteLe    DateTime @default(now())

  @@unique([litigeId, votantId])
  @@map("votes_litiges")
}

// ─────────────────────────────────────────
// MESSAGERIE
// ─────────────────────────────────────────

model Message {
  id          String   @id @default(uuid())
  tontine     Tontine  @relation(fields: [tontineId], references: [id])
  tontineId   String
  expediteur  User     @relation(fields: [expediteurId], references: [id])
  expediteurId String
  contenu     String
  estAnnonce  Boolean  @default(false)
  createdAt   DateTime @default(now())

  lectures    LectureMessage[]

  @@map("messages")
}

model LectureMessage {
  id        String   @id @default(uuid())
  message   Message  @relation(fields: [messageId], references: [id])
  messageId String
  membreId  String
  luLe      DateTime @default(now())

  @@unique([messageId, membreId])
  @@map("lectures_messages")
}

// ─────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────

enum TypeNotification {
  PAIEMENT_DU
  PAIEMENT_RECU
  DISTRIBUTION
  RAPPEL
  LITIGE
  ANNONCE
  SYSTEME
}

model Notification {
  id        String           @id @default(uuid())
  user      User             @relation(fields: [userId], references: [id])
  userId    String
  titre     String
  corps     String
  type      TypeNotification
  lu        Boolean          @default(false)
  lienAction String?
  createdAt DateTime         @default(now())

  @@map("notifications")
}

// ─────────────────────────────────────────
// AUDIT LOG (immuable)
// ─────────────────────────────────────────

model AuditLog {
  id          String   @id @default(uuid())
  acteur      User?    @relation(fields: [acteurId], references: [id])
  acteurId    String?
  tontine     Tontine? @relation(fields: [tontineId], references: [id])
  tontineId   String?
  action      String
  entiteType  String
  entiteId    String?
  anciennesValeurs Json?
  nouvellesValeurs Json?
  adresseIp   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

// ─────────────────────────────────────────
// OTP CODES (connexion par téléphone)
// ─────────────────────────────────────────

model OtpCode {
  id        String   @id @default(uuid())
  telephone String
  code      String
  expireAt  DateTime
  utilise   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@map("otp_codes")
}
